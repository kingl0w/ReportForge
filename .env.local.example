# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_PER_REPORT_PRICE_ID=price_your-per-report-price-id

# Google Gemini (free tier — narrative generation only)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token


# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Cron secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET=

# Resend (email delivery)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=reports@yourdomain.com

# Shopify (OAuth for data connections)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# eBay (OAuth for data connections)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_SANDBOX=false

# Admin (logging & abuse monitoring)
ADMIN_SECRET=change-this-to-a-random-string
ADMIN_EMAIL=your-email@example.com
NEXT_PUBLIC_ADMIN_EMAIL=your-email@example.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Smoke tests (optional — scripts/smoke-test.ts)
# SMOKE_TEST_EMAIL=smoke-test@test.reportforge.com
# SMOKE_TEST_PASSWORD=your-secure-password-here
