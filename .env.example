# ===========================================
# ReportForge Environment Variables
# ===========================================
# Copy this file to .env and fill in all values.
# Never commit .env to version control.

# --- Supabase ---
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Database ---
# Supabase Postgres connection string (pooled recommended for serverless)
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# --- Stripe ---
# Secret key from Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret from Stripe dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Publishable key — safe to expose in browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Price IDs for subscription and per-report plans
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_PER_REPORT_PRICE_ID=price_your-per-report-price-id

# --- Google Gemini (free tier — narrative generation only) ---
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# --- Redis ---
# Local Docker: redis://redis:6379
# Upstash (production): your Upstash REST URL
REDIS_URL=redis://redis:6379

# Upstash REST credentials (used by @upstash/redis client)
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# --- Resend (email delivery) ---
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=reports@yourdomain.com

# --- Encryption ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Cron ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# --- Admin (logging & abuse monitoring) ---
# Secret for admin API routes — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change-this-to-a-random-string
# Your email — gates access to admin dashboard and sidebar link
ADMIN_EMAIL=your-email@example.com
NEXT_PUBLIC_ADMIN_EMAIL=your-email@example.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
